# Copy this file to .env and fill in real values.

# === Mail sending ===
# Choose a provider: "smtp2go" (HTTP API), "graph" (M365 work accounts) or "smtp".
# Leave blank to auto-detect (graph → smtp2go → smtp by which creds are present).
MAIL_PROVIDER=smtp2go

# --- Option A: SMTP2GO (HTTP API) — only needs the api key + a verified sender ---
SMTP2GO_API_KEY=api-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP2GO_API_URL=https://api.smtp2go.com/v3

# --- Option B: Microsoft Graph (app-only) — for @affa.az work accounts ---
# From an Entra ID app registration with Mail.Send APPLICATION permission
# (admin consent granted). No mailbox password is needed.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Mailbox the automatic emails are sent FROM (e.g. noreply@affa.az)
MAIL_SENDER=noreply@affa.az

# --- Option C: SMTP (SMTP2GO-over-SMTP, or personal/Outlook.com) ---
# SMTP2GO over SMTP: host mail-eu.smtp2go.com, port 2525 (or 587/8025), and an
# SMTP_USER / SMTP_PASS created as an "SMTP user" in the SMTP2GO dashboard.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-address@yourdomain.com
SMTP_PASS=your-app-password
# Optional: address shown in the "From" field (defaults to SMTP_USER)
MAIL_FROM=your-address@yourdomain.com

# --- API protection (Bearer token) ---
# The frontend must send this same token (set it in the app's Parametrlər tab).
# Leave blank in local dev to run the API unprotected (a warning is logged).
API_TOKEN=change-me-to-a-long-random-string

# --- PFL Partners API (live data source) ---
PFL_BASE_URL=https://pfl.az/api/v1/partners
PFL_ACCESS_TOKEN=your-pfl-access-token
# psignSecret from PFL (often equals the access token). Used for the HMAC Psign.
PFL_PSIGN_SECRET=your-pfl-psign-secret

# --- Server ---
PORT=3001
